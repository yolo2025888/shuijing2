<view catchtap="handleCloseNaming" class="modal-layer" wx:if="{{namingPayload}}">
    <view class="modal-backdrop"></view>
    <view catchtap="handleNoop" class="sheet sheet--naming">
        <view class="sheet-pill"></view>
        <view class="name-modal-header">
            <view class="modal-spacer"></view>
            <view class="modal-text-group">
                <text class="modal-main-title">为你的作品命名</text>
                <text class="modal-sub-title">请输入 2-10 个字符</text>
            </view>
            <button catchtap="handleCloseNaming" class="modal-close-btn">
                <image class="close-icon" mode="aspectFit" src="{{assetUiBaseUrl}}/icons/close-muted.svg"></image>
            </button>
        </view>
        <view class="naming-input-wrap">
            <input bindinput="handleNamingInput" class="naming-input" maxlength="10" placeholder="请输入 2-10 个字符" value="{{namingValue}}"></input>
        </view>
        <view class="naming-actions">
            <button catchtap="handleCloseNaming" class="naming-btn naming-btn--ghost">取消</button>
            <button catchtap="handleNamingConfirm" class="naming-btn naming-btn--primary">确认保存</button>
        </view>
    </view>
</view>
<view catchtap="handleCloseWristSetting" class="modal-layer modal-layer--center modal-layer--wrist" wx:if="{{wristSettingOpen}}">
    <view class="modal-backdrop"></view>
    <view catchtap="handleNoop" class="wrist-sheet">
        <view class="wrist-sheet__header">
            <view class="wrist-sheet__title-wrap">
                <view class="wrist-sheet__icon-wrap">
                    <image class="wrist-sheet__icon" mode="aspectFit" src="{{assetUiBaseUrl}}/icons/ruler-dark.svg"></image>
                </view>
                <text class="wrist-sheet__title">设置手围</text>
            </view>
            <button catchtap="handleCloseWristSetting" class="wrist-sheet__close">
                <image class="wrist-sheet__close-icon" mode="aspectFit" src="{{assetUiBaseUrl}}/icons/close-muted.svg"></image>
            </button>
        </view>
        <view class="wrist-control-card">
            <view class="wrist-control-card__value-row">
                <button catchtap="handleWristDecrease" class="wrist-step-btn">
                    <text class="wrist-step-btn__text">-</text>
                </button>
                <view class="wrist-control-card__value-block">
                    <text class="wrist-control-card__value">{{wristDraftValueDisplay}}</text>
                    <text class="wrist-control-card__unit">CM</text>
                </view>
                <button catchtap="handleWristIncrease" class="wrist-step-btn">
                    <text class="wrist-step-btn__text">+</text>
                </button>
            </view>
            <view class="wrist-control-card__slider-wrap" id="wristSliderTrack">
                <slider activeColor="transparent" backgroundColor="#E7E0D2" bindchange="handleWristSliderChange" bindchanging="handleWristSliderChanging" blockColor="#2C312E" blockSize="16" class="wrist-control-card__slider" max="21" min="14" showValue="{{false}}" step="0.5" value="{{wristDraftValue}}"></slider>
            </view>
            <view class="wrist-control-card__ticks">
                <text class="wrist-control-card__tick">14</text>
                <text class="wrist-control-card__tick">15</text>
                <text class="wrist-control-card__tick">16</text>
                <text class="wrist-control-card__tick">17</text>
                <text class="wrist-control-card__tick">18</text>
                <text class="wrist-control-card__tick">19</text>
                <text class="wrist-control-card__tick">20</text>
                <text class="wrist-control-card__tick">21</text>
            </view>
        </view>
        <text class="wrist-sheet__subtext">手围会影响推荐串长与佩戴贴合度，后续可随时在此处修改。</text>
        <view class="wrist-sheet__actions">
            <button catchtap="handleConfirmWristSetting" class="wrist-sheet__btn wrist-sheet__btn--primary">确认</button>
            <button catchtap="handleClearWristSetting" class="wrist-sheet__btn wrist-sheet__btn--ghost">清除设置（恢复未设置）</button>
        </view>
    </view>
</view>
<view catchtap="handleCloseShareCard" class="modal-layer modal-layer--center" wx:if="{{showDiyShareModal}}">
    <view class="modal-backdrop"></view>
    <view catchtap="handleNoop" class="share-modal">
        <view class="share-modal__head">
            <text class="share-modal__title">分享作品海报</text>
            <text class="share-modal__desc">保存后可发送给朋友或分享到社交平台</text>
        </view>
        <view class="share-modal__body">
            <view class="share-preview">
                <view class="share-preview__brand">
                    <image class="share-preview__brand-logo" mode="aspectFit" src="{{assetUiBaseUrl}}/SLLOGO.svg"></image>
                    <text class="share-preview__brand-title">灵感石验室</text>
                </view>
                <text class="share-preview__headline">我在 DIY 工坊完成了一条原创手串，欢迎来灵感石验室一起创作。</text>
                <view class="share-preview__hero">
                    <image class="share-preview__hero-bg" mode="aspectFill" src="{{currentTrayBg.url}}"></image>
                    <view class="share-preview__bracelet-layer">
                        <mini-bracelet beadSize="{{18}}" containerSize="{{160}}" pattern="{{trayState.pattern}}"></mini-bracelet>
                    </view>
                </view>
                <view class="share-preview__foot">
                    <view class="share-preview__foot-copy">
                        <image class="share-preview__foot-icon" mode="aspectFit" src="{{assetUiBaseUrl}}/icons/share-lock-dark.svg"></image>
                        <text>分享你的设计，好友采用后可获得最高 <text class="share-preview__foot-highlight">15%</text> 共创收益</text>
                    </view>
                </view>
            </view>
        </view>
        <view class="share-modal__actions">
            <button catchtap="handleCloseShareCard" class="share-modal__btn">我知道了</button>
        </view>
    </view>
</view>
<view catchtap="handleCloseProfileShareModal" class="modal-layer modal-layer--center" wx:if="{{showProfileShareModal}}">
    <view class="modal-backdrop"></view>
    <view catchtap="handleNoop" class="share-modal">
        <view class="share-modal__head">
            <text class="share-modal__title">分享创作者海报</text>
            <text class="share-modal__desc">将你的创作者信息分享给好友，获取更多关注</text>
        </view>
        <view class="share-modal__body">
            <view class="share-preview">
                <view class="share-preview__brand">
                    <image class="share-preview__brand-logo" mode="aspectFit" src="{{assetUiBaseUrl}}/SLLOGO.svg"></image>
                    <text class="share-preview__brand-title">灵感石验室</text>
                </view>
                <text class="share-preview__headline">我已加入灵感石验室创作者计划，欢迎查看我的原创设计。</text>
                <view class="share-preview__hero">
                    <image class="share-preview__hero-bg" mode="aspectFill" src="{{currentTrayBg.url}}" wx:if="{{currentTrayBg}}"></image>
                    <view class="share-preview__bracelet-layer">
                        <mini-bracelet beadSize="{{18}}" containerSize="{{160}}" pattern="{{profileSharePattern}}"></mini-bracelet>
                    </view>
                </view>
                <view class="share-preview__foot">
                    <view class="share-preview__foot-copy">
                        <image class="share-preview__foot-icon" mode="aspectFit" src="{{assetUiBaseUrl}}/icons/star-gold.svg"></image>
                        <text>设计被采用可获得最高 <text class="share-preview__foot-highlight">15%</text> 共创收益</text>
                    </view>
                </view>
            </view>
        </view>
        <view class="share-modal__actions">
            <button catchtap="handleCloseProfileShareModal" class="share-modal__btn">我知道了</button>
        </view>
    </view>
</view>
