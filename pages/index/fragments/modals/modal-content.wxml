<view
  catchtap="handleCloseContentModal"
  class="modal-layer"
  wx:if="{{showContentModal}}"
>
  <view class="modal-backdrop"></view>
  <view catchtap="handleNoop" class="sheet sheet--content">
    <view class="sheet-pill"></view>
    <view class="order-modal-header">
      <view class="header-spacer"></view>
      <view class="header-title">{{contentModalTitle||'服务内容'}}</view>
      <view catchtap="handleCloseContentModal" class="header-close">
        <image
          class="close-icon order-modal-header__close-icon"
          mode="aspectFit"
          src="{{assetUiBaseUrl}}/icons/close-muted.svg"
        ></image>
      </view>
    </view>
    <scroll-view
      enableFlex
      scrollY
      class="content-sheet-body"
      showScrollbar="false"
    >
      <view class="content-sheet-loading" wx:if="{{contentModalLoading}}"
        >内容加载中...</view
      >
      <view wx:else>
        <view class="content-sheet-warning" wx:if="{{contentModalError}}"
          >{{contentModalError}}</view
        >
        <view class="white-card">
          <text class="content-sheet-text"
            >{{contentModalText||'暂无内容'}}</text
          >
        </view>
      </view>
      <view class="sheet-scroll-spacer"></view>
    </scroll-view>
  </view>
</view>
